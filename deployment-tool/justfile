# Justfile for Avatar Deployment Tool
# Run `just` or `just --list` to see available commands

PATHS := (
 "src" +
 " tests")

# Show available commands
default:
    @just --list

# Install dependencies
install:
    uv sync --all-extras

# Install the CLI into the local project virtualenv
install-tool: install
    uv pip install --editable . --no-deps

# Run all tests (excluding integration tests by default)
test *ARGS:
    uv run pytest tests/unit {{ARGS}}

# Run integration tests only
test-integration *ARGS:
    uv run pytest tests/integration {{ARGS}}

# Run all tests including integration tests
test-all *ARGS:test test-integration

update-test-fixtures:
    AVATAR_DEPLOY_UPDATE_FIXTURES=1 just test-integration

# Lint code with ruff
lint: format
    uv run ruff check {{PATHS}}

# Format code with ruff
format:
    uv run ruff format {{PATHS}}
    uv run ruff check --fix {{PATHS}}

# Format and lint
lint-fix: format lint

# Check types with pyright
typecheck:
    uv run pyright

lci: lint-fix typecheck test-all


# Build the package
build:
    rm -rf dist/
    uv build

# Run the deploy command with GitHub templates in a test directory
run-interactive-github *ARGS: install-tool
    #!/usr/bin/env bash
    set -- {{ARGS}}
    if [ "${1:-}" = "--" ]; then
        shift
    fi
    TEST_DIR=$(mktemp -d)
    echo "Running in temporary directory: $TEST_DIR"
    uv run octopize-deploy-tool deploy --output-dir "$TEST_DIR" --verbose "$@"
    echo "\nGenerated files in: $TEST_DIR"
    ls -la "$TEST_DIR"

# Run the deploy command with local templates in a test directory
run-local-deploy *ARGS: install-tool
    #!/usr/bin/env bash
    set -- {{ARGS}}
    if [ "${1:-}" = "--" ]; then
        shift
    fi
    TEST_DIR=$(mktemp -d)
    echo "Running in temporary directory: $TEST_DIR"
    uv run octopize-deploy-tool deploy --output-dir "$TEST_DIR" --template-from ../docker/templates --verbose "$@"
    echo "\nGenerated files in: $TEST_DIR"
    ls -la "$TEST_DIR"

# Run the generate-env command with local templates in a test directory
run-local-generate-env *ARGS: install-tool
    #!/usr/bin/env bash
    set -- {{ARGS}}
    if [ "${1:-}" = "--" ]; then
        shift
    fi
    TEST_DIR=$(mktemp -d)
    echo "Running in temporary directory: $TEST_DIR"
    mkdir -p "$TEST_DIR/api" "$TEST_DIR/web" "$TEST_DIR/python_client"
    uv run octopize-deploy-tool generate-env \
        --api-output-path "$TEST_DIR/api/.env" \
        --web-output-path "$TEST_DIR/web/.env" \
        --python-client-output-path "$TEST_DIR/python_client/.env" \
        --template-from ../docker/templates \
        --verbose \
        "$@"
    echo "\nGenerated files in: $TEST_DIR"
    find "$TEST_DIR" -maxdepth 2 -type f | sort

run-interactive-local *ARGS:
    just run-local-deploy {{ARGS}}



# Run the help command
help:
    uv run octopize-deploy-tool --help

# Show defaults.yaml content
show-defaults:
    @cat src/octopize_avatar_deploy/defaults.yaml

# Publish package to PyPI
release: build
    uv publish

# Get current version from pyproject.toml
@get-version:
    grep '^version = ' pyproject.toml | sed 's/version = "\(.*\)"/\1/'

# Update project version markers that should track releases
@set-version new_version:
    #!/usr/bin/env bash
    set -euo pipefail
    python - "{{new_version}}" <<'PY'
    from pathlib import Path
    import re
    import sys

    new_version = sys.argv[1]
    version_markers = [
        (Path("pyproject.toml"), r'^version = "[^"]+"$', f'version = "{new_version}"'),
        (
            Path("src/octopize_avatar_deploy/__init__.py"),
            r'^__version__ = "[^"]+"$',
            f'__version__ = "{new_version}"',
        ),
    ]

    for path, pattern, replacement in version_markers:
        content = path.read_text()
        updated_content, replacements = re.subn(
            pattern,
            replacement,
            content,
            count=1,
            flags=re.MULTILINE,
        )
        if replacements != 1:
            raise SystemExit(f"Expected to update exactly one version marker in {path}")
        path.write_text(updated_content)
    PY
    uv lock >/dev/null

# Bump patch version (0.1.0 -> 0.1.1)
bump-patch:
    #!/usr/bin/env bash
    set -euo pipefail
    current=$(just get-version)
    new_version=$(echo $current | awk -F. '{print $1"."$2"."$3+1}')
    just set-version "$new_version"
    git add pyproject.toml src/octopize_avatar_deploy/__init__.py uv.lock
    git commit -m "chore: bump version to $new_version"
    git tag -a "deploy-tool-v$new_version" -m "Release version $new_version"
    echo "✓ Bumped version to $new_version and created tag deploy-tool-v$new_version"
    echo "  Push with: git push && git push --tags"

# Bump minor version (0.1.0 -> 0.2.0)
bump-minor:
    #!/usr/bin/env bash
    set -euo pipefail
    current=$(just get-version)
    new_version=$(echo $current | awk -F. '{print $1"."$2+1".0"}')
    just set-version "$new_version"
    git add pyproject.toml src/octopize_avatar_deploy/__init__.py uv.lock
    git commit -m "chore: bump version to $new_version"
    git tag -a "deploy-tool-v$new_version" -m "Release version $new_version"
    echo "✓ Bumped version to $new_version and created tag deploy-tool-v$new_version"
    echo "  Push with: git push && git push --tags"

# Bump major version (0.1.0 -> 1.0.0)
bump-major:
    #!/usr/bin/env bash
    set -euo pipefail
    current=$(just get-version)
    new_version=$(echo $current | awk -F. '{print $1+1".0.0"}')
    just set-version "$new_version"
    git add pyproject.toml src/octopize_avatar_deploy/__init__.py uv.lock
    git commit -m "chore: bump version to $new_version"
    git tag -a "deploy-tool-v$new_version" -m "Release version $new_version"
    echo "✓ Bumped version to $new_version and created tag deploy-tool-v$new_version"
    echo "  Push with: git push && git push --tags"
